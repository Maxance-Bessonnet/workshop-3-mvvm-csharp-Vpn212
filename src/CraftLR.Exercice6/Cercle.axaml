<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CraftLR.Exercice6.Cercle"
        Title="Binding two way"
        Height="600" Width="500"
        RequestedThemeVariant="Light">
    <StackPanel Orientation="Vertical" Spacing="20" Margin="20">

        <Slider Name="RadiusSlider"
                Minimum="0" Maximum="500"
                Value="150"
                TickFrequency="10"
                IsSnapToTickEnabled="True" />

        <Panel Width="500" Height="500">
            <Ellipse Name="CentralEllipse"
                     Fill="Black"
                     Height="{Binding Path=Value, ElementName=RadiusSlider}"
                     Width="{Binding RelativeSource={RelativeSource Self}, Path=Height}" />
        </Panel>

        <TextBox Text="{Binding Path=Value, ElementName=RadiusSlider, Mode=TwoWay}"
                 HorizontalAlignment="Center"
                 Width="100" />

    </StackPanel>
</Window>